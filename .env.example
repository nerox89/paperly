# ── Required ──────────────────────────────────────────────────────────────────
# URL of your Paperless-NGX instance (from within Docker: container name + port)
PAPERLESS_URL=http://paperless-ngx:8000

# Paperless-NGX API token — create one under Settings → API Tokens
PAPERLESS_TOKEN=your_paperless_api_token_here

# ── AI backend ────────────────────────────────────────────────────────────────
# Choose "claude" (default) or "ollama"
PAPERLY_AI_PROVIDER=claude

# Anthropic Claude — required when PAPERLY_AI_PROVIDER=claude
ANTHROPIC_API_KEY=your_anthropic_api_key_here
PAPERLY_CLAUDE_MODEL=claude-haiku-4-5

# Ollama — required when PAPERLY_AI_PROVIDER=ollama
PAPERLY_OLLAMA_URL=http://localhost:11434
PAPERLY_OLLAMA_MODEL=gemma4:e4b

# ── Optional ──────────────────────────────────────────────────────────────────
# Minimum confidence (0–1) for auto-applying suggestions in batch mode
# PAPERLY_AUTO_APPLY_CONFIDENCE=0.85

# Number of parallel workers in batch mode
# PAPERLY_BATCH_CONCURRENCY=3

# Directory for the SQLite database file (paperly.db)
# PAPERLY_DATA_DIR=.

# Port and host for the web server
# PAPERLY_PORT=8002
# PAPERLY_HOST=0.0.0.0

# Public URL for PDF preview links — set this when Paperless-NGX is on an
# internal address but you access paperly from a browser on a different host
# PAPERLY_PAPERLESS_PUBLIC_URL=https://paperless.example.com
